# Environment Variables - DO NOT COMMIT REAL VALUES
# This file shows what environment variables are needed
# Create a .env.local file with actual values (add to .gitignore)

# ========================================
# API Configuration
# ========================================

# Supabase Service Role Token (for backend API calls in test scripts)
# ⚠️ SECURITY: Never commit real tokens!
# Get from Supabase project settings: Settings → API → Service Role Key
BEARER_TOKEN=your_supabase_service_role_token_here

# Backend API URL
API_URL=http://localhost:5000

# Frontend URL
FRONTEND_URL=http://localhost:3000

# ========================================
# Supabase Configuration
# ========================================

# Supabase Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (safe for frontend)
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ========================================
# Storage Configuration (R2/S3)
# ========================================

# Cloudflare R2 Configuration
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=nian-storage
R2_ACCOUNT_ID=your_account_id
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ========================================
# Sentry Configuration (Error Tracking)
# ========================================

VITE_SENTRY_DSN=your_sentry_dsn_here
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ========================================
# IMPORTANT SECURITY NOTES
# ========================================
#
# 1. Add .env.local, .env.*.local to .gitignore
#
#    echo ".env.local" >> .gitignore
#    echo ".env.*.local" >> .gitignore
#
# 2. Create .env.local with REAL values:
#
#    cp .env.example .env.local
#    # Edit .env.local with real credentials
#
# 3. NEVER commit real tokens, keys, or secrets
#
# 4. Rotate tokens immediately if exposed
#
# 5. Use GitHub secret scanning to detect leaks
#
# 6. Check for exposed secrets in git history:
#
#    git log -p | grep -i "token\|key\|secret"
#
# 7. If secrets were exposed:
#
#    # Rotate compromised tokens in Supabase/Cloudflare
#    # Use git-filter-branch or BFG repo cleaner to remove from history
#    # Force push after cleaning history
#
# ========================================
